{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "npm test -- --watchAll=false 2>&1 | tail -5; exit ${PIPESTATUS[0]}",
            "timeout": 60000,
            "description": "Block commits unless tests pass"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --no-error-on-unmatched-pattern $CLAUDE_FILE 2>&1 | tail -10 || true",
            "timeout": 15000,
            "description": "Auto-lint after file changes (non-blocking hint)"
          }
        ]
      }
    ]
  }
}
