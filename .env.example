# RC Digital LLC CRM — Environment Variables
# Copy this file to .env and fill in your values

# ==========================================
# SUPABASE (Required)
# ==========================================
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SB_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE

# ==========================================
# GOOGLE OAUTH (Required for Auth)
# ==========================================
# Get from: Google Cloud Console → APIs & Services → Credentials
# Set redirect URI to: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# GMAIL API (Phase 7 - Optional)
# ==========================================
# Get from: Google Cloud Console → Enable Gmail API
VITE_GMAIL_CLIENT_ID=your-gmail-client-id.apps.googleusercontent.com

# ==========================================
# GOOGLE CALENDAR API (Phase 7 - Optional)
# ==========================================
# Get from: Google Cloud Console → Enable Calendar API
VITE_GCAL_CLIENT_ID=your-gcal-client-id.apps.googleusercontent.com

# ==========================================
# POSTHOG ANALYTICS (Phase 7 - Optional)
# ==========================================
# Get from: PostHog → Project Settings
VITE_POSTHOG_KEY=phc_YOUR_POSTHOG_KEY
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ==========================================
# APP CONFIG
# ==========================================
VITE_APP_NAME="RC Digital CRM"
VITE_APP_COMPANY="RC Digital LLC"
